{
  "name": "@missing-ai-patterns/registry",
  "version": "0.5.1",
  "description": "The MAP registry contract — the machine-readable pattern catalog schema, its TypeScript types, and a validating parser shared by every MAP tool.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/missing-ai-patterns/sdk.git",
    "directory": "packages/registry"
  },
  "homepage": "https://github.com/missing-ai-patterns/patterns",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "architecture",
    "patterns",
    "registry",
    "catalog",
    "schema"
  ],
  "dependencies": {
    "@missing-ai-patterns/score": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
