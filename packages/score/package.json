{
  "name": "@missing-ai-patterns/score",
  "version": "0.4.0",
  "description": "MAP Score — a compact 1–5 star rating system for AI architecture patterns. Schema, validation, and rendering.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/missing-ai-patterns/cli.git",
    "directory": "packages/score"
  },
  "homepage": "https://github.com/missing-ai-patterns/map",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
